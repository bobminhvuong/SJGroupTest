# ============================================================================
# DEV Dockerfile — runs start:dev (hot-reload). Source is mounted via compose volume.
# Build context = project root (see docker-compose.dev.yml)
# ============================================================================
FROM node:20-alpine
WORKDIR /app

# Install full deps (including devDependencies for ts-node/nest watch)
COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 3000
CMD ["npm", "run", "start:dev"]
