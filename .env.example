# App
NODE_ENV=development
PORT=3000

# PostgreSQL (dev)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=booking

# PostgreSQL (test) — DB riêng cho e2e, KHÔNG trùng DB dev để tránh mất dữ liệu
DB_TEST_HOST=localhost
DB_TEST_PORT=5432
DB_TEST_USERNAME=postgres
DB_TEST_PASSWORD=postgres
DB_TEST_DATABASE=booking_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache / Lock
LOCATION_TREE_CACHE_TTL=600
BOOKING_LOCK_TTL_MS=5000

# CORS — comma-separated allowed origins. Leave empty to allow all (dev only).
CORS_ORIGIN=
