# ============================================================================
# Dockerfile DEV — chạy start:dev (hot-reload). Source mount qua compose volume.
# Build context = thư mục gốc project (xem docker-compose.dev.yml)
# ============================================================================
FROM node:20-alpine
WORKDIR /app

# Cài full deps (gồm devDependencies cho ts-node/nest watch)
COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 3000
CMD ["npm", "run", "start:dev"]
